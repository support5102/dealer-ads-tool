# Required — app will not start without these
SESSION_SECRET=generate-a-random-secret-here
GOOGLE_ADS_CLIENT_ID=your-oauth-client-id
GOOGLE_ADS_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
ANTHROPIC_API_KEY=your-anthropic-api-key

# App URL (required for OAuth — must match Google Cloud Console redirect URI)
APP_URL=http://localhost:3000

# MCC manager account ID (optional, auto-discovered if not set)
GOOGLE_MANAGER_ACCOUNT_ID=123-456-7890

# Claude model (optional, defaults to claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Server config
PORT=3000
NODE_ENV=development

# Freshdesk webhook (optional — only needed for webhook integration)
FRESHDESK_WEBHOOK_KEY=your-webhook-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token-for-webhook-mode

# Pacing Engine v2 - set to "true" to enable daily scheduler + new columns
PACING_ENGINE_V2_ENABLED=false
